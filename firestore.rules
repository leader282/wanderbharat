rules_version = '2';

// Minimal but safe rules for the MVP.
//
// - `nodes` and `edges` are world-readable reference data (cities, routes).
// - `itineraries` are readable by their owner, writable only by the server
//   (admin SDK, which bypasses these rules).
// - `users` are readable/writable by the owner only.
//
// The admin SDK bypasses these rules entirely, so the API routes + seed
// scripts work regardless of how strict these get.
service cloud.firestore {
  match /databases/{database}/documents {
    match /nodes/{nodeId} {
      allow read: if true;
      allow write: if false;
    }

    match /edges/{edgeId} {
      allow read: if true;
      allow write: if false;
    }

    match /itineraries/{itineraryId} {
      allow read: if resource.data.user_id == null
        || (request.auth != null && request.auth.uid == resource.data.user_id);
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

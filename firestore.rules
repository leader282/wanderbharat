rules_version = '2';

// Minimal but safe rules for the MVP.
//
// - `nodes`, `edges`, `accommodations`, and `regions` are world-readable
//   reference data.
// - `itineraries` are readable by their owner (anonymous itineraries are
//   readable by anyone with the id).
// - `users` are self-readable but server-write only. This is critical:
//   the user doc carries the `role` field consumed by requireAdminUser(),
//   so allowing client writes would let any signed-in account self-promote
//   to admin via the Firebase SDK.
//
// All writes are server-only: the admin SDK bypasses these rules entirely,
// so the API routes + seed scripts can mutate every collection regardless
// of how strict client-side rules get.
service cloud.firestore {
  match /databases/{database}/documents {
    match /nodes/{nodeId} {
      allow read: if true;
      allow write: if false;
    }

    match /edges/{edgeId} {
      allow read: if true;
      allow write: if false;
    }

    match /accommodations/{accommodationId} {
      allow read: if true;
      allow write: if false;
    }

    match /regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }

    match /itineraries/{itineraryId} {
      allow read: if resource.data.user_id == null
        || (request.auth != null && request.auth.uid == resource.data.user_id);
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}

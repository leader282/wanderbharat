# =============================================================================
# wanderbharat — environment variable template.
#
# Copy to `.env.local` for local dev, and add the same variables in your
# Vercel project settings (Production + Preview + Development).
#
# NEVER commit `.env.local` or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase client (browser-safe — must be prefixed with NEXT_PUBLIC_).
# Found in Firebase Console → Project settings → General → Your apps.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Optional: named Firestore database id. Leave empty to use the default DB.
NEXT_PUBLIC_FIREBASE_DATABASE_ID=

# -----------------------------------------------------------------------------
# Firebase Admin (server-only — used by API routes + seed scripts).
#
# Pick ONE of:
#   - FIREBASE_SERVICE_ACCOUNT_JSON: paste the base64-encoded service-account
#     JSON (recommended for Vercel — production + preview). Raw JSON is also
#     accepted for backwards compatibility.
#   - FIREBASE_SERVICE_ACCOUNT_PATH: absolute path to a JSON file
#     (recommended for local dev only — never commit the file).
# If both are unset, the SDK falls back to GOOGLE_APPLICATION_CREDENTIALS.
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# -----------------------------------------------------------------------------
# Google Maps Platform.
#
# - GOOGLE_MAPS_API_KEY (server-only)
#     Used by lib/services/distanceService.ts + placesService.ts and the
#     seed scripts. Lock it down in Google Cloud Console:
#       Application restrictions: None (server) OR IP allow-list
#       API restrictions:         Routes API, Places API (New)
#
# - NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY (shipped to the browser)
#     Used only by the Maps JavaScript API on /itinerary/:id. This key is
#     visible in client bundles, so it MUST be locked down or anyone can
#     burn your quota:
#       Application restrictions: HTTP referrers — your prod + preview
#                                 domains (e.g. https://wanderbharat.app/*,
#                                 https://*.vercel.app/*, http://localhost:3000/*)
#       API restrictions:         Maps JavaScript API only
#     Use a SEPARATE key from GOOGLE_MAPS_API_KEY — never reuse the
#     server key here.
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY=

# -----------------------------------------------------------------------------
# LiteAPI Hotel Data (server-only).
#
# LiteAPI is used only for hotel discovery + rate snapshots in prototype v2.
# Booking/prebook/payment endpoints are intentionally out of scope.
# -----------------------------------------------------------------------------
LITEAPI_ENABLED=false
LITEAPI_API_KEY=
# Optional override. Defaults to https://api.liteapi.travel/v3.0
LITEAPI_BASE_URL=
# Request timeout in milliseconds.
LITEAPI_TIMEOUT_MS=12000
# Max rows requested per provider call.
LITEAPI_MAX_RESULTS=20

{
  "name": "wanderbharat",
  "version": "0.1.0",
  "private": true,
  "description": "Generic travel planning engine. Region datasets live under scripts/data/ and are loaded by slug.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.ts\"",
    "test": "node scripts/runNodeTests.mjs",
    "test:watch": "node scripts/runNodeTests.mjs --watch",
    "test:coverage": "node -e \"require('fs').mkdirSync('coverage',{recursive:true})\" && node scripts/runNodeTests.mjs --experimental-test-coverage --test-coverage-exclude=\"**/*.test.ts\" --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "test:itinerary:stress": "tsx scripts/runItineraryStress.ts --profile=quick",
    "test:itinerary:stress:quick": "tsx scripts/runItineraryStress.ts --profile=quick",
    "test:itinerary:stress:heavy": "tsx scripts/runItineraryStress.ts --profile=heavy",
    "test:itinerary:stress:replay": "tsx scripts/runItineraryStress.ts --profile=replay",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm test && npm run test:itinerary:stress",
    "db:purge": "tsx scripts/purge.ts",
    "grant:admin": "tsx scripts/grantAdmin.ts",
    "seed:nodes": "tsx scripts/seedNodes.ts",
    "seed:attractions": "tsx scripts/seedAttractions.ts",
    "seed:attraction-hours": "tsx scripts/seedAttractionHours.ts",
    "seed:attraction-admissions": "tsx scripts/seedAttractionAdmissions.ts",
    "seed:edges": "tsx scripts/seedEdges.ts",
    "seed:accommodations": "tsx scripts/seedAccommodations.ts",
    "seed:all": "tsx scripts/seedNodes.ts --all && tsx scripts/seedAttractions.ts --all && tsx scripts/seedAttractionHours.ts --all && tsx scripts/seedAttractionAdmissions.ts --all && tsx scripts/seedEdges.ts --all && tsx scripts/seedAccommodations.ts --all"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.17.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.64.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^6"
  }
}
